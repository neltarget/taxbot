# Groq API key for the LLM backend
GROQ_API_KEY=your_groq_api_key_here

# Model to use (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Comma-separated list of allowed CORS origins for production
# Example: ALLOWED_ORIGINS=https://taxbot.vercel.app,https://taxbot.onrender.com
# ALLOWED_ORIGINS=
